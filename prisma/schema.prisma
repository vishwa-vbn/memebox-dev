generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           BigInt   @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  role         Role     @default(SUPREMEADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  SUPREMEADMIN
}

model Media {
  id              BigInt    @id @default(autoincrement())
  imagekitFileId  String?   @db.VarChar(255)

  title           String?   @db.VarChar(255)
  description     String?

  mediaType       MediaType

  fileUrl         String    @db.VarChar(500)
  thumbnailUrl    String?   @db.VarChar(500)
  previewUrl      String?   @db.VarChar(500)

  width           Int?
  height          Int?
  duration        Float?
  fileSize        Int?

  categoryId      BigInt?
  isNsfw          Boolean   @default(false)

  views           Int       @default(0)
  downloads       Int       @default(0)
  shares          Int       @default(0)
  likes           Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  category        Category? @relation(fields: [categoryId], references: [id])
  tags            MediaTag[]
  emotions        MediaEmotion[]
  analytics       MediaAnalytic[]

  @@index([mediaType])
  @@index([categoryId])
  @@index([views, downloads])
  @@index([title])
}

enum MediaType {
  GIF
  STICKER
  MEME
}

model Tag {
  id         BigInt   @id @default(autoincrement())
  name       String   @unique @db.VarChar(100)
  slug       String?  @db.VarChar(100)
  usageCount Int      @default(0)

  media      MediaTag[]
}

model MediaTag {
  mediaId BigInt
  tagId   BigInt

  media   Media @relation(fields: [mediaId], references: [id],onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id])

  @@id([mediaId, tagId])
}

model Category {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(100)
  slug        String?  @unique @db.VarChar(100)
  description String?
  icon        String?  @db.VarChar(255)
  createdAt   DateTime @default(now())

  media       Media[]
}

model Emotion {
  id     BigInt      @id @default(autoincrement())
  name   String      @db.VarChar(50)
  emoji  String?     @db.VarChar(10)

  media  MediaEmotion[]
}

model MediaEmotion {
  mediaId   BigInt
  emotionId BigInt

  media     Media   @relation(fields: [mediaId], references: [id],onDelete: Cascade)
  emotion   Emotion @relation(fields: [emotionId], references: [id])

  @@id([mediaId, emotionId])
}

model MediaAnalytic {
  id        BigInt     @id @default(autoincrement())
  mediaId   BigInt
  eventType EventType
  createdAt DateTime   @default(now())

  media     Media      @relation(fields: [mediaId], references: [id],onDelete: Cascade)
}

enum EventType {
  VIEW
  DOWNLOAD
  SHARE
}

model Ad {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(100)
  provider  String?  @db.VarChar(100)
  placement String?  @db.VarChar(100)
  adScript  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}