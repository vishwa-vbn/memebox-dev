generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            BigInt    @id @default(autoincrement())
  email         String    @unique @db.VarChar(255)
  passwordHash  String    @db.VarChar(255)
  role          Role      @default(USER)
  isEmailVerified Boolean @default(false)
  emailVerifiedAt DateTime?

  emailVerificationOtp    String?   @db.VarChar(6)
  emailVerificationOtpExpiresAt DateTime?

  passwordResetToken      String?   @db.VarChar(100)
  passwordResetTokenExpiresAt DateTime?

  credits            Int @default(0)
  totalCreditsEarned Int @default(0)
  creditTransactions CreditTransaction[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  likes         MediaLike[]
  submissions   Media[]
  views         MediaView[]
  contacts      Contact[]
}

enum Role {
  SUPREMEADMIN
  USER
}

model Media {
  id BigInt @id @default(autoincrement())
  imagekitFileId String? @db.VarChar(255)
  title String? @db.VarChar(255)
  description String?
  mediaType MediaType
  fileUrl String @db.VarChar(500)
  thumbnailUrl String? @db.VarChar(500)
  previewUrl String? @db.VarChar(500)
  width Int?
  height Int?
  duration Float?
  fileSize Int?

  categoryId BigInt?
  submittedById BigInt?



  status MediaStatus @default(PENDING)
  isNsfw Boolean @default(false)

  views Int @default(0)
  downloads Int @default(0)
  shares Int @default(0)
  likes Int @default(0)

  likesList MediaLike[]
  viewsList MediaView[]
  creditTransactions CreditTransaction[]

  submittedBy User? @relation(fields: [submittedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category Category? @relation(fields: [categoryId], references: [id])
  tags MediaTag[]
  emotions MediaEmotion[]
  analytics MediaAnalytic[]

  @@index([mediaType])
  @@index([categoryId])
  @@index([views, downloads])
  @@index([title])
}

model MediaView {
  id          BigInt   @id @default(autoincrement())
  mediaId     BigInt
  userId      BigInt?
  ipAddress   String?  @db.VarChar(45)
  fingerprint String?  @db.VarChar(64)
  viewedAt    DateTime @default(now())

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([mediaId, userId])
  @@unique([mediaId, fingerprint])

  @@index([mediaId])
}



enum MediaStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MediaType {
  GIF
  STICKER
  MEME
}

model Tag {
  id         BigInt   @id @default(autoincrement())
  name       String   @unique @db.VarChar(100)
  slug       String   @unique @db.VarChar(100)
  usageCount Int      @default(0)

  media      MediaTag[]
}

model MediaTag {
  mediaId BigInt
  tagId   BigInt

  media   Media @relation(fields: [mediaId], references: [id],onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id])

  @@id([mediaId, tagId])
}

model Category {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(100)
  slug        String?  @unique @db.VarChar(100)
  description String?
  icon        String?  @db.VarChar(255)
  createdAt   DateTime @default(now())

  media       Media[]
}

model Emotion {
  id     BigInt @id @default(autoincrement())
  name   String @unique @db.VarChar(50)  
  slug   String @unique @db.VarChar(50)
  emoji  String? @db.VarChar(10)

  media  MediaEmotion[]
}

model MediaEmotion {
  mediaId   BigInt
  emotionId BigInt

  media     Media   @relation(fields: [mediaId], references: [id],onDelete: Cascade)
  emotion   Emotion @relation(fields: [emotionId], references: [id])

  @@id([mediaId, emotionId])
}

model MediaAnalytic {
  id        BigInt     @id @default(autoincrement())
  mediaId   BigInt
  eventType EventType
  createdAt DateTime   @default(now())

  media     Media      @relation(fields: [mediaId], references: [id],onDelete: Cascade)
}

enum EventType {
  VIEW
  DOWNLOAD
  SHARE
}

model Ad {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(100)
  provider  String?  @db.VarChar(100)
  placement String?  @db.VarChar(100)
  adScript  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model MediaLike {
  id      BigInt @id @default(autoincrement())
  mediaId BigInt
  userId  BigInt

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mediaId, userId])
}

//////////////////////////////////////////////////////
// 💰 CREDIT SYSTEM (NO REDEMPTION YET)
//////////////////////////////////////////////////////

enum CreditSource {
  SUBMISSION_APPROVED
  MEDIA_VIEW_MILESTONE
  MEDIA_LIKE_MILESTONE
  OTHER
}

model CreditTransaction {
  id          BigInt       @id @default(autoincrement())
  userId      BigInt
  amount      Int
  source      CreditSource
  description String?      @db.VarChar(200)
  mediaId     BigInt?
  createdAt   DateTime     @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  media       Media?       @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([source])
}

//////////////////////////////////////////////////////
// 📩 CONTACT SYSTEM
//////////////////////////////////////////////////////

enum ContactStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Contact {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(255)
  subject   String   @db.VarChar(200)
  message   String
  status    ContactStatus @default(OPEN)
  adminNote String?  @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status])
}