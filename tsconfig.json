{
  "compilerOptions": {
    /* Basic Options */
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "types": ["node"],
    
    /* Strictness */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "skipLibCheck": true,

    /* Interop & Pathing */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",

    /* Vercel Compatibility */
    "noEmit": true, 
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false, // Change to false to allow auto-elision of type imports

    /* Path Mapping (To fix those 'Cannot find module' errors) */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    /* Other Settings */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}